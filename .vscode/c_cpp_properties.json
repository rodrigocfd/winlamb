{
	"configurations": [
		{
			"name": "Win32",
			"includePath": [
				"${workspaceFolder}/**"
			],
			"defines": [
				"_DEBUG",
				"UNICODE",
				"_UNICODE"
			],
			"compilerArgs": [
				"/diagnostics:column",
				"/EHsc",
				"/FC",
				"/GA",
				"/GS",
				"/MDd",
				"/MP",
				"/nologo",
				"/Od",
				"/permissive-",
				"/std:c++20",
				"/W3",
				"/Zc:forScope",
				"/Zc:wchar_t",
				"/ZI"
			],
			"compilerPath": "cl.exe",
			"cppStandard": "c++20",
			"intelliSenseMode": "windows-msvc-x64"
		}
	],
	"version": 4
}
